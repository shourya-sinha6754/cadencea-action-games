<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>I'm Sorry ❤️</title>
  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(to right, #ff9a9e, #fad0c4);
      color: #333;
      overflow-x: hidden;
    }

    header {
      text-align: center;
      padding: 60px 20px;
      color: white;
    }

    header h1 {
      font-size: 3em;
    }

    header p {
      font-size: 1.2em;
    }

    section {
      padding: 50px 20px;
      text-align: center;
    }

    .card {
      background: white;
      padding: 20px;
      margin: 20px auto;
      border-radius: 20px;
      max-width: 800px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .gallery {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 15px;
    }

    .gallery img {
      width: 200px;
      height: 200px;
      object-fit: cover;
      border-radius: 15px;
      transition: transform 0.3s;
    }

    .gallery img:hover {
      transform: scale(1.1);
    }

    button {
      padding: 15px 25px;
      font-size: 16px;
      border: none;
      border-radius: 25px;
      background: #ff6f91;
      color: white;
      cursor: pointer;
      transition: 0.3s;
    }

    button:hover {
      background: #ff3e6c;
    }

    .hidden {
      display: none;
    }

    footer {
      text-align: center;
      padding: 20px;
      color: white;
    }

    .heart {
      position: fixed;
      top: -10px;
      color: red;
      animation: fall linear forwards;
    }

    @keyframes fall {
      to {
        transform: translateY(100vh);
      }
    }
  </style>
</head>
<body>

<header>
  <h1>I'm Really Sorry ❤️</h1>
  <p>Please read this... it's from my heart</p>
</header>

<section>
  <div class="card">
    <h2>To My Love 💖</h2>
    <p>
      I know I messed up... and I hate seeing you upset because of me.
      You mean everything to me, and I never wanted to hurt you.
      I'm truly, deeply sorry.
    </p>
  </div>
</section>

<section>
  <div class="card">
    <h2>Our Memories 📸</h2>
    <p>These are some of my favorite moments with you</p>

    <div class="gallery">
      <!-- INSERT HER IMAGE 1 HERE -->
      <img src="image1.jpg" alt="Memory 1">

      <!-- INSERT HER IMAGE 2 HERE -->
      <img src="image2.jpg" alt="Memory 2">

      <!-- INSERT HER IMAGE 3 HERE -->
      <img src="image3.jpg" alt="Memory 3">

      <!-- INSERT HER IMAGE 4 HERE -->
      <img src="image4.jpg" alt="Memory 4">
    </div>
  </div>
</section>

<section>
  <div class="card">
    <h2>Why You're Special 🌹</h2>
    <p>
      Your smile makes my day better.
      Your voice is my favorite sound.
      Your happiness means everything to me.
      I never want to lose you.
    </p>
  </div>
</section>

<section>
  <div class="card">
    <h2>Click This ❤️</h2>
    <button onclick="showMessage()">Click Me</button>
    <p id="secretMessage" class="hidden">
      I promise to do better. I love you more than words can explain.
      Please forgive me ❤️
    </p>
  </div>
</section>

<footer>
  <p>Made with love ❤️</p>
</footer>

<script>
  function showMessage() {
    document.getElementById("secretMessage").classList.remove("hidden");
  }

  function createHeart() {
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * window.innerWidth + "px";
    heart.style.animationDuration = Math.random() * 3 + 2 + "s";
    document.body.appendChild(heart);

    setTimeout(() => {
      heart.remove();
    }, 5000);
  }

  setInterval(createHeart, 300);
</script>

</body>
</html>

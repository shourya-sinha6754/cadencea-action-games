<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I'm Sorry ❤️</title>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(to right, #ff9a9e, #fad0c4);
            color: #333;
            overflow-x: hidden;
        }

        header {
            text-align: center;
            padding: 60px 20px;
            color: white;
        }

        header h1 {
            font-size: 3em;
        }

        header p {
            font-size: 1.2em;
        }

        section {
            padding: 50px 20px;
            text-align: center;
        }

        .card {
            background: white;
            padding: 20px;
            margin: 20px auto;
            border-radius: 20px;
            max-width: 800px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
        }

        .gallery img {
            width: 200px;
            height: 200px;
            object-fit: cover;
            border-radius: 15px;
            transition: transform 0.3s;
        }

        .gallery img:hover {
            transform: scale(1.1);
        }

        button {
            padding: 15px 25px;
            font-size: 16px;
            border: none;
            border-radius: 25px;
            background: #ff6f91;
            color: white;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #ff3e6c;
        }

        .hidden {
            display: none;
        }

        footer {
            text-align: center;
            padding: 20px;
            color: white;
        }

        .heart {
            position: fixed;
            top: -10px;
            color: red;
            animation: fall linear forwards;
        }

        @keyframes fall {
            to {
                transform: translateY(100vh);
            }
        }
    </style>
</head>

<body>

    <header>
        <h1>I'm Really Sorry ❤️ Gajralli👀</h1>
        <p>Chl lo Meraki, plzzzzzzzzzzzzzzzzzzzz</p>
    </header>

    <section>
        <div class="card">
            <h2>To My Love 💖</h2>
            <p>
                maaf kr de yrr, chl lo ghumne. bahut din ho gye hai. plzzzzz. I'm sorry yr. i don't want any fights yr.
            </p>
        </div>
    </section>



    <section>
        <div class="card">
            <h2>Why You're Special 🌹</h2>
            <p>
                coz you are mineeeeee!!!! bas baat khtm
            </p>
        </div>
    </section>

    <section>
        <div class="card">
            <h2>Click This ❤️</h2>
            <button onclick="showMessage()">Click Me</button>
            <p id="secretMessage" class="hidden">
                SOrrrrrrry. I know bahut cringe tarika hai yeh, but hai toh hai. kr de maaf aab, chl le.
            </p>
        </div>
    </section>

    <footer>
        <p>from personal billa</p>
    </footer>

    <script>
        function showMessage() {
            document.getElementById("secretMessage").classList.remove("hidden");
        }

        function createHeart() {
            const heart = document.createElement("div");
            heart.classList.add("heart");
            heart.innerHTML = "❤️";
            heart.style.left = Math.random() * window.innerWidth + "px";
            heart.style.animationDuration = Math.random() * 3 + 2 + "s";
            document.body.appendChild(heart);

            setTimeout(() => {
                heart.remove();
            }, 5000);
        }

        setInterval(createHeart, 300);
    </script>

</body>

</html>

    <style>
        body {
            margin: 0;
            background: #121212;
            font-family: sans-serif;
            color: white;
        }

        /* HEADER */
        .header {
            background: linear-gradient(180deg, #000, #252525);
            padding: 40px 20px;
            text-align: center;
            border-bottom: 4px solid red;
        }

        .logo {
            font-family: 'Orbitron';
            font-size: 8vw;
            letter-spacing: 6px;
            margin: 0;
            transition: 0.3s;
            display: inline-block;
        }

        /* 🔥 HOVER ANIMATION BACK */
        .logo:hover {
            transform: scale(1.1);
            text-shadow: 0 0 20px white, 0 0 40px white;
        }

        .header h3 {
            color: #ff4d4d;
            letter-spacing: 2px;
        }

        /* GAME CARD */
        .game {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            padding: 30px;
            align-items: center;
        }

        .game img {
            width: 100%;
            max-width: 300px;
            border-radius: 10px;
            border: 2px solid #333;
            transition: 0.3s;
        }

        /* 🔥 RED GLOW EFFECT BACK */
        .game img:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px red, 0 0 40px red;
        }

        .game-text {
            flex: 1;
            font-size: 16px;
            line-height: 1.6;
        }

        .title {
            color: red;
            font-family: 'Orbitron';
            margin-left: 30px;
        }

        /* FOOTER */
        footer {
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            text-align: center;
            padding: 30px;
        }

        /* MOBILE FIX */
        @media (max-width: 768px) {
            .game {
                flex-direction: column;
                text-align: center;
            }

            .title {
                text-align: center;
                margin-left: 0;
            }

            /* Disable hover scaling on mobile (prevents glitch) */
            .logo:hover,
            .game img:hover {
                transform: none;
                box-shadow: none;
                text-shadow: none;
            }
        }

        /* POPUP */
        .popup {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
        }

        .popup-content {
            background: #1e2a38;
            padding: 20px;
            margin: 30% auto;
            width: 80%;
            max-width: 300px;
            text-align: center;
            border-radius: 10px;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .popup button {
            margin-top: 10px;
            padding: 8px 15px;
            background: cyan;
            border: none;
            cursor: pointer;
        }
    </style>
</head>

